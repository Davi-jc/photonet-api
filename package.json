{
  "name": "photonet-api",
  "version": "1.0.0",
  "description": "API REST de rede social de fotos — Trabalho Final Cloud Computing UNIDAVI",
  "main": "api/app.js",
  "scripts": {
    "start": "node api/app.js",
    "test": "jest --coverage",
    "lint": "eslint api/**/*.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["api/**/*.js", "!api/tests/**"]
  }
}
